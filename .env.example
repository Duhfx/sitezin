# ─────────────────────────────────────────────────────────────────
# Variáveis de ambiente — copie para .env.local (dev) ou importe no
# Vercel (Settings → Environment Variables → Import .env).
# Substitua os valores de exemplo pelos reais antes de usar.
# ─────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────
# Painel Supabase → Project Settings → Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sua-publishable-key
SUPABASE_SECRET_KEY=sua-secret-key

# ── URL pública da aplicação ──────────────────────────────────────
# Usada para montar os links do mídia kit enviados por WhatsApp.
# Defina o domínio de produção SEM barra no final.
# Ao trocar de domínio, faça um novo deploy para os links atualizarem.
NEXT_PUBLIC_APP_URL=https://seu-dominio.vercel.app

# ── Meta / Instagram Graph API ────────────────────────────────────
# Painel: developers.facebook.com → seu app → Configurações → Básico
META_APP_ID=seu-app-id
META_APP_SECRET=seu-app-secret

# ── TikTok (Display API) ──────────────────────────────────────────
# Painel: developers.tiktok.com → seu app → Manage apps → credenciais
TIKTOK_CLIENT_KEY=seu-client-key
TIKTOK_CLIENT_SECRET=seu-client-secret

# ── Cron Job (sync automático de métricas) ───────────────────────
# Gere um valor aleatório forte (ex: openssl rand -hex 32) e cadastre
# também no Vercel → Settings → Environment Variables.
# O Vercel injeta esse valor no header Authorization: Bearer {CRON_SECRET}
# em cada disparo do cron configurado no vercel.json.
CRON_SECRET=seu-cron-secret-aleatorio

# ── Resend (e-mail) — necessário só se for ativar envio por e-mail ─
RESEND_API_KEY=sua-resend-api-key
RESEND_FROM_EMAIL=contato@seudominio.com
